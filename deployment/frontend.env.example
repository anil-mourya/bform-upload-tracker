# Frontend Environment Configuration
# Copy this file to .env and update with your values
# Note: Variables must be prefixed with REACT_APP_ to be accessible in React

# Environment
REACT_APP_ENV=production
REACT_APP_VERSION=1.0.0
REACT_APP_DEBUG=false

# API Configuration
REACT_APP_API_BASE_URL=https://api.yourdomain.com
REACT_APP_API_TIMEOUT=30000

# Authentication
REACT_APP_JWT_STORAGE_KEY=auth_token
REACT_APP_SESSION_STORAGE_KEY=session
REACT_APP_ENABLE_REMEMBER_ME=true
REACT_APP_OAUTH_CLIENT_ID=your-oauth-client-id
REACT_APP_OAUTH_REDIRECT_URI=https://yourdomain.com/auth/callback

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_TWO_FACTOR=true
REACT_APP_ENABLE_EXPORT=true

# External Services
REACT_APP_SENTRY_DSN=https://your-key@sentry.io/your-project
REACT_APP_SENTRY_ENVIRONMENT=production
REACT_APP_SENTRY_SAMPLE_RATE=0.1

# Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_MIXPANEL_TOKEN=

# UI Configuration
REACT_APP_THEME=light
REACT_APP_PRIMARY_COLOR=#1f2937
REACT_APP_SECONDARY_COLOR=#3b82f6
REACT_APP_ITEMS_PER_PAGE=10

# File Upload
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# Notifications
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_NOTIFICATION_TIMEOUT=5000

# App URLs
REACT_APP_APP_URL=https://yourdomain.com
REACT_APP_SUPPORT_EMAIL=support@yourdomain.com
REACT_APP_DOCUMENTATION_URL=https://docs.yourdomain.com

# Maps (if needed)
REACT_APP_GOOGLE_MAPS_KEY=

# Stripe (if payment processing)
REACT_APP_STRIPE_PUBLIC_KEY=

# S3 Bucket (for direct uploads)
REACT_APP_S3_BUCKET=bform-tracker-uploads
REACT_APP_S3_REGION=us-east-1
